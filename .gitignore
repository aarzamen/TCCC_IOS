# macOS
.DS_Store

# Xcode
build/
DerivedData/
*.xcuserstate
*.xcuserdatad/
xcuserdata/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# Swift Package Manager
.build/
.swiftpm/
Packages/*/.build/
Packages/*/.swiftpm/

# Python developer tools
__pycache__/
*.py[cod]

# Generated local run artifacts
artifacts/

# Reference materials are local-only
reference/design_mockup/

# Rubric source bundles (Apple Books exports, ~235 MB) are local-only —
# the curated extracts in reference/rubric/extracted/ ARE tracked, since
# the codebase binds to them as ground truth for the 2026 sprint.
reference/rubric/*
!reference/rubric/extracted/
